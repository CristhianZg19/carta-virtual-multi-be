NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/restaurant_menu
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
JWT_SECRET=change-this-secret-before-production
JWT_EXPIRES_IN=7d
LOG_FORMAT=text
